# App
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=debug

# Database (SQLite for dev; Postgres in production)
DATABASE_URL=file:./data/barakahpay.db

# JWT
JWT_SECRET=change-this-in-production-please-use-something-random
JWT_EXPIRES_IN=7d

# CORS (comma-separated origins for prod)
CORS_ORIGIN=http://localhost:3000

# Stellar network
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org:443
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Deployed contracts (testnet)
ESCROW_CONTRACT_ID=CBE7HHQI3F7NGPKRILKFQNZYDSSZBN27BSJSOE3EVYKLJ6YXXPYZQPGA
REGISTRY_CONTRACT_ID=CAAH5I3TKPRGJ74ONQVDG2V7XKA5R5KW352UU4SHTXFYCBOYY34PMASJ

# Admin account (holds admin auth for contracts; keep secret in production)
STELLAR_ADMIN_SECRET=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute
